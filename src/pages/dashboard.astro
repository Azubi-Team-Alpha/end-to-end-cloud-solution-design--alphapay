---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `Dashboard | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  <!-- Guard: redirect if not logged in (handled via JS below) -->
  <div id="dashboard-root" class="hidden">
    
    <!-- Welcome bar -->
    <div class="border-b border-neutral-200/80 bg-gradient-to-r from-blue-600 to-indigo-600 dark:border-neutral-700/60">
      <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-blue-200">Welcome back 👋</p>
            <h2 id="user-greeting" class="text-xl font-bold text-white">Loading…</h2>
          </div>
          <div class="flex items-center gap-3">
            <span id="account-badge" class="hidden rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">Personal</span>
            <button
              id="logout-btn"
              class="rounded-xl border border-white/30 bg-white/10 px-4 py-2 text-xs font-semibold text-white backdrop-blur-sm transition hover:bg-white/20"
            >
              Sign out
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      
      <!-- ── Balance + Quick Actions Row ──────────────────────────────────── -->
      <div class="mb-8 grid gap-6 lg:grid-cols-3">
        
        <!-- Balance Card -->
        <div class="col-span-1 flex flex-col justify-between overflow-hidden rounded-3xl bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-700 p-6 text-white shadow-2xl shadow-blue-500/20 lg:col-span-2">
          <div class="flex items-start justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-blue-200">Total Balance</p>
              <p id="user-balance" class="mt-1 text-4xl font-extrabold tracking-tight">GH₵ 0.00</p>
              <p class="mt-1 text-sm text-blue-200">≈ $0 USD &nbsp;·&nbsp; <span class="text-green-300 font-medium">+12.4% this month</span></p>
            </div>
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
          </div>

          <!-- Quick Action Buttons -->
          <div class="mt-6 flex gap-3">
            {[
              { label: 'Send', icon: '↑', action: 'send' },
              { label: 'Receive', icon: '↓', action: 'receive' },
              { label: 'Top Up', icon: '+', action: 'topup' },
              { label: 'History', icon: '≡', action: 'history' },
            ].map(btn => (
              <button
                data-action={btn.action}
                class="quick-action flex flex-1 flex-col items-center gap-1.5 rounded-2xl bg-white/10 px-2 py-3 text-center backdrop-blur-sm transition hover:bg-white/20 active:scale-95"
              >
                <span class="text-lg font-bold">{btn.icon}</span>
                <span class="text-[11px] font-semibold">{btn.label}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Stats Card -->
        <div class="col-span-1 rounded-3xl border border-neutral-200/80 bg-white p-6 shadow-lg dark:border-neutral-700/60 dark:bg-neutral-900">
          <h3 class="mb-4 text-sm font-bold text-neutral-700 dark:text-neutral-300">This Month</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-green-100 dark:bg-green-900/30">
                  <span class="text-sm text-green-600 dark:text-green-400">↓</span>
                </div>
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Money In</span>
              </div>
              <span class="text-sm font-bold text-green-600 dark:text-green-400">+GH₵ 6,200</span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2.5">
                <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-red-100 dark:bg-red-900/30">
                  <span class="text-sm text-red-500 dark:text-red-400">↑</span>
                </div>
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Money Out</span>
              </div>
              <span class="text-sm font-bold text-red-500 dark:text-red-400">-GH₵ 1,380</span>
            </div>
            <div class="border-t border-neutral-100 pt-3 dark:border-neutral-800">
              <div class="flex items-center justify-between">
                <span class="text-sm text-neutral-600 dark:text-neutral-400">Net savings</span>
                <span class="text-sm font-bold text-blue-600 dark:text-blue-400">GH₵ 4,820</span>
              </div>
            </div>
            <div>
              <div class="mb-1 flex justify-between text-xs text-neutral-500 dark:text-neutral-400">
                <span>Monthly goal</span>
                <span>78%</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-neutral-100 dark:bg-neutral-800">
                <div class="h-2 rounded-full bg-gradient-to-r from-blue-500 to-indigo-500" style="width: 78%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Main Grid ──────────────────────────────────────────────────────── -->
      <div class="grid gap-6 lg:grid-cols-3">
        
        <!-- Recent Transactions -->
        <div class="col-span-1 rounded-3xl border border-neutral-200/80 bg-white shadow-lg dark:border-neutral-700/60 dark:bg-neutral-900 lg:col-span-2">
          <div class="flex items-center justify-between border-b border-neutral-100 px-6 py-4 dark:border-neutral-800">
            <h3 class="font-bold text-neutral-800 dark:text-neutral-200">Recent Transactions</h3>
            <button class="text-xs font-semibold text-blue-600 hover:underline dark:text-blue-400">View all</button>
          </div>
          <div class="divide-y divide-neutral-50 px-6 dark:divide-neutral-800/50">
            {[
              { initials: 'KA', color: 'bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-400', name: 'Kofi Agyeman', time: 'Today, 10:24 AM', amount: '+GH₵ 500', type: 'in', note: 'Freelance payment' },
              { initials: 'AB', color: 'bg-green-100 dark:bg-green-900/40 text-green-600 dark:text-green-400', name: 'Ama Boateng', time: 'Yesterday, 3:11 PM', amount: '-GH₵ 150', type: 'out', note: 'Lunch split' },
              { initials: 'MM', color: 'bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400', name: 'MTN MoMo', time: 'Mon, 9:00 AM', amount: '+GH₵ 1,200', type: 'in', note: 'Wallet top-up' },
              { initials: 'DY', color: 'bg-purple-100 dark:bg-purple-900/40 text-purple-600 dark:text-purple-400', name: 'David Yirenkyi', time: 'Sun, 2:45 PM', amount: '-GH₵ 75', type: 'out', note: 'Shared taxi' },
              { initials: 'ZA', color: 'bg-orange-100 dark:bg-orange-900/40 text-orange-600 dark:text-orange-400', name: 'Zakaria Adeeba', time: 'Sat, 11:30 AM', amount: '+GH₵ 320', type: 'in', note: 'Debt repayment' },
            ].map(tx => (
              <div class="flex items-center justify-between py-4 transition hover:bg-neutral-50/50 dark:hover:bg-neutral-800/30 -mx-2 px-2 rounded-xl cursor-pointer">
                <div class="flex items-center gap-4">
                  <div class={`flex h-10 w-10 items-center justify-center rounded-2xl text-xs font-bold shrink-0 ${tx.color}`}>
                    {tx.initials}
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-200">{tx.name}</p>
                    <p class="text-xs text-neutral-500 dark:text-neutral-400">{tx.note} · {tx.time}</p>
                  </div>
                </div>
                <span class={`text-sm font-bold ${tx.type === 'in' ? 'text-green-600 dark:text-green-400' : 'text-red-500 dark:text-red-400'}`}>
                  {tx.amount}
                </span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right column -->
        <div class="col-span-1 flex flex-col gap-6">
          
          <!-- Send Money Card -->
          <div class="rounded-3xl border border-neutral-200/80 bg-white p-6 shadow-lg dark:border-neutral-700/60 dark:bg-neutral-900">
            <h3 class="mb-4 font-bold text-neutral-800 dark:text-neutral-200">Quick Send</h3>
            <div class="space-y-3">
              <div>
                <label class="mb-1 block text-xs font-semibold text-neutral-600 dark:text-neutral-400">Recipient</label>
                <input
                  type="text"
                  id="send-recipient"
                  placeholder="Name, email, or phone"
                  class="block w-full rounded-xl border border-neutral-200 bg-neutral-50 px-3.5 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder-neutral-500"
                />
              </div>
              <div>
                <label class="mb-1 block text-xs font-semibold text-neutral-600 dark:text-neutral-400">Amount (GH₵)</label>
                <input
                  type="number"
                  id="send-amount"
                  placeholder="0.00"
                  min="1"
                  class="block w-full rounded-xl border border-neutral-200 bg-neutral-50 px-3.5 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder-neutral-500"
                />
              </div>
              <button id="send-btn"
                class="w-full rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-4 py-2.5 text-sm font-bold text-white shadow-md shadow-blue-500/20 transition hover:from-blue-500 hover:to-indigo-500 active:scale-[0.98] focus:outline-none">
                Send Money →
              </button>
            </div>
            <!-- Send feedback -->
            <div id="send-feedback" class="mt-3 hidden rounded-xl bg-green-50 px-3 py-2.5 text-xs text-green-700 dark:bg-green-950/30 dark:text-green-400">
              ✅ Transfer sent successfully!
            </div>
          </div>

          <!-- Security Status Card -->
          <div class="rounded-3xl border border-neutral-200/80 bg-white p-6 shadow-lg dark:border-neutral-700/60 dark:bg-neutral-900">
            <h3 class="mb-4 flex items-center gap-2 font-bold text-neutral-800 dark:text-neutral-200">
              <span>🛡️</span> Account Security
            </h3>
            <div class="space-y-2.5">
              {[
                { label: '2FA Enabled', ok: true },
                { label: 'Email verified', ok: true },
                { label: 'KYC status', ok: false, status: 'Pending' },
                { label: 'PIN set', ok: true },
              ].map(item => (
                <div class="flex items-center justify-between">
                  <span class="text-xs text-neutral-600 dark:text-neutral-400">{item.label}</span>
                  {item.ok
                    ? <span class="rounded-md bg-green-100 px-2 py-0.5 text-[10px] font-bold text-green-700 dark:bg-green-900/30 dark:text-green-400">✅ Active</span>
                    : <span class="rounded-md bg-yellow-100 px-2 py-0.5 text-[10px] font-bold text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400">⚠ {item.status}</span>
                  }
                </div>
              ))}
            </div>
          </div>

          <!-- Supported Wallets -->
          <div class="rounded-3xl border border-neutral-200/80 bg-white p-6 shadow-lg dark:border-neutral-700/60 dark:bg-neutral-900">
            <h3 class="mb-3 font-bold text-neutral-800 dark:text-neutral-200">Linked Wallets</h3>
            <div class="space-y-2">
              {[
                { name: 'MTN MoMo', num: '024 *** 456', color: 'bg-yellow-400' },
                { name: 'Telecel Cash', num: '050 *** 789', color: 'bg-red-500' },
              ].map(w => (
                <div class="flex items-center gap-3 rounded-xl bg-neutral-50 px-3 py-2.5 dark:bg-neutral-800">
                  <div class={`h-2.5 w-2.5 rounded-full ${w.color}`}></div>
                  <div class="min-w-0">
                    <p class="text-xs font-semibold text-neutral-700 dark:text-neutral-300">{w.name}</p>
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400">{w.num}</p>
                  </div>
                </div>
              ))}
              <button class="w-full rounded-xl border border-dashed border-neutral-300 py-2 text-xs font-semibold text-neutral-500 transition hover:border-blue-400 hover:text-blue-600 dark:border-neutral-700 dark:text-neutral-400 dark:hover:border-blue-500 dark:hover:text-blue-400">
                + Link wallet
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Action Modal (generic) -->
  <div id="action-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-neutral-900/60 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-3xl border border-neutral-200 bg-white p-8 shadow-2xl dark:border-neutral-700 dark:bg-neutral-900">
      <h3 id="modal-title" class="mb-2 text-lg font-bold text-neutral-900 dark:text-neutral-100">Action</h3>
      <p id="modal-body" class="text-sm text-neutral-500 dark:text-neutral-400">Coming soon in the full version.</p>
      <button id="modal-close" class="mt-5 w-full rounded-xl bg-blue-600 py-2.5 text-sm font-bold text-white hover:bg-blue-500">Close</button>
    </div>
  </div>
</MainLayout>

<script>
  // ── Auth Guard ────────────────────────────────────────────────────────────────
  const rawUser = localStorage.getItem('alphapay_user');
  if (!rawUser) {
    window.location.href = '/signin';
  } else {
    const user = JSON.parse(rawUser);

    // Show dashboard
    const root = document.getElementById('dashboard-root')!;
    root.classList.remove('hidden');

    // Fill greeting & balance
    document.getElementById('user-greeting')!.textContent = `Hello, ${user.name}!`;
    document.getElementById('user-balance')!.textContent = user.balance || 'GH₵ 0.00';

    if (user.accountType) {
      const badge = document.getElementById('account-badge')!;
      badge.textContent = user.accountType === 'business' ? '🏢 Business' : '👤 Personal';
      badge.classList.remove('hidden');
    }

    // New user welcome
    if (user.isNew) {
      document.getElementById('user-balance')!.textContent = 'GH₵ 0.00';
      user.isNew = false;
      localStorage.setItem('alphapay_user', JSON.stringify(user));
    }
  }

  // ── Sign out ──────────────────────────────────────────────────────────────────
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('alphapay_user');
    window.location.href = '/';
  });

  // ── Quick action buttons ──────────────────────────────────────────────────────
  const modalEl = document.getElementById('action-modal')!;
  const modalTitle = document.getElementById('modal-title')!;
  const modalBody = document.getElementById('modal-body')!;
  const modalClose = document.getElementById('modal-close')!;

  const actionInfo: Record<string, { title: string; body: string }> = {
    send: { title: '💸 Send Money', body: 'Use the Quick Send card on the right to transfer money instantly.' },
    receive: { title: '📥 Receive Money', body: 'Your AlphaPay ID: alphapay/' + (JSON.parse(localStorage.getItem('alphapay_user') || '{}').email || 'you') + '\n\nShare this with anyone to receive money.' },
    topup: { title: '💳 Top Up Wallet', body: 'Link a bank card or mobile money wallet to add funds to your AlphaPay balance.' },
    history: { title: '📊 Transaction History', body: 'Full statement download and filtering coming in the full platform release.' },
  };

  document.querySelectorAll('.quick-action').forEach(btn => {
    btn.addEventListener('click', () => {
      const action = btn.getAttribute('data-action') || 'send';
      const info = actionInfo[action] || { title: 'Coming Soon', body: 'This feature will be available soon.' };
      modalTitle.textContent = info.title;
      modalBody.textContent = info.body;
      modalEl.classList.remove('hidden');
      modalEl.classList.add('flex');
    });
  });

  modalClose.addEventListener('click', () => {
    modalEl.classList.add('hidden');
    modalEl.classList.remove('flex');
  });
  modalEl.addEventListener('click', (e) => {
    if (e.target === modalEl) {
      modalEl.classList.add('hidden');
      modalEl.classList.remove('flex');
    }
  });

  // ── Quick Send ────────────────────────────────────────────────────────────────
  document.getElementById('send-btn')?.addEventListener('click', async () => {
    const recipient = (document.getElementById('send-recipient') as HTMLInputElement).value.trim();
    const amount = (document.getElementById('send-amount') as HTMLInputElement).value;

    if (!recipient || !amount || Number(amount) <= 0) {
      alert('Please enter a valid recipient and amount.');
      return;
    }

    const btn = document.getElementById('send-btn') as HTMLButtonElement;
    btn.textContent = 'Sending…';
    btn.disabled = true;

    await new Promise(r => setTimeout(r, 1200));

    document.getElementById('send-feedback')!.classList.remove('hidden');
    (document.getElementById('send-recipient') as HTMLInputElement).value = '';
    (document.getElementById('send-amount') as HTMLInputElement).value = '';
    btn.textContent = 'Send Money →';
    btn.disabled = false;

    setTimeout(() => document.getElementById('send-feedback')!.classList.add('hidden'), 3000);
  });
</script>
