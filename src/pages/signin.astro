---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `Sign In | ${SITE.title}`;
const metaDescription = 'Sign in to your AlphaPay account to send, receive, and manage money across Africa.';
const ogTitle = 'Sign In | AlphaPay';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
>
  <section class="flex min-h-[calc(100vh-80px)] items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
      <!-- Card -->
      <div class="relative overflow-hidden rounded-3xl border border-neutral-200/80 bg-white shadow-2xl dark:border-neutral-700/60 dark:bg-neutral-900">
        <!-- Top gradient bar -->
        <div class="h-1.5 w-full bg-gradient-to-r from-blue-500 via-indigo-500 to-blue-600"></div>

        <div class="p-8 sm:p-10">
          <!-- Logo & Heading -->
          <div class="mb-8 text-center">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 shadow-lg shadow-blue-500/30">
              <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
            <h1 class="text-2xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100">Welcome back</h1>
            <p class="mt-1.5 text-sm text-neutral-500 dark:text-neutral-400">Sign in to your AlphaPay account</p>
          </div>

          <!-- Error / Success alert (hidden by default) -->
          <div id="signin-error" class="mb-4 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800/50 dark:bg-red-950/30 dark:text-red-400" role="alert">
            <span id="signin-error-msg">Invalid email or password. Please try again.</span>
          </div>
          <div id="signin-success" class="mb-4 hidden rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-800/50 dark:bg-green-950/30 dark:text-green-400" role="alert">
            ✅ Signing you in…
          </div>

          <!-- Form -->
          <form id="signin-form" novalidate>
            <div class="space-y-5">
              <!-- Email -->
              <div>
                <label for="signin-email" class="mb-1.5 block text-sm font-semibold text-neutral-700 dark:text-neutral-300">
                  Email address
                </label>
                <input
                  type="email"
                  id="signin-email"
                  name="email"
                  autocomplete="email"
                  placeholder="you@example.com"
                  class="block w-full rounded-xl border border-neutral-300 bg-neutral-50 px-4 py-3 text-sm text-neutral-900 placeholder-neutral-400 transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder-neutral-500 dark:focus:border-blue-500 dark:focus:bg-neutral-800/70"
                />
                <p id="email-error" class="mt-1.5 hidden text-xs text-red-500">Please enter a valid email address.</p>
              </div>

              <!-- Password -->
              <div>
                <div class="mb-1.5 flex items-center justify-between">
                  <label for="signin-password" class="block text-sm font-semibold text-neutral-700 dark:text-neutral-300">Password</label>
                  <a href="/forgot-password" class="text-xs font-medium text-blue-600 hover:text-blue-700 hover:underline dark:text-blue-400">Forgot password?</a>
                </div>
                <div class="relative">
                  <input
                    type="password"
                    id="signin-password"
                    name="password"
                    autocomplete="current-password"
                    placeholder="••••••••"
                    class="block w-full rounded-xl border border-neutral-300 bg-neutral-50 px-4 py-3 pr-11 text-sm text-neutral-900 placeholder-neutral-400 transition focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder-neutral-500 dark:focus:border-blue-500 dark:focus:bg-neutral-800/70"
                  />
                  <button type="button" id="toggle-password" class="absolute inset-y-0 right-3 flex items-center text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300" tabindex="-1">
                    <svg id="eye-show" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    <svg id="eye-hide" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                  </button>
                </div>
                <p id="password-error" class="mt-1.5 hidden text-xs text-red-500">Password must be at least 8 characters.</p>
              </div>

              <!-- Remember me -->
              <div class="flex items-center gap-x-2">
                <input type="checkbox" id="remember-me" name="remember" class="h-4 w-4 rounded border-neutral-300 text-blue-600 accent-blue-600 dark:border-neutral-600" />
                <label for="remember-me" class="text-sm text-neutral-600 dark:text-neutral-400">Keep me signed in</label>
              </div>

              <!-- Submit button -->
              <button
                type="submit"
                id="signin-btn"
                class="relative w-full overflow-hidden rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 px-5 py-3.5 text-sm font-bold text-white shadow-lg shadow-blue-500/30 transition-all duration-300 hover:from-blue-500 hover:to-indigo-500 hover:shadow-blue-500/40 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
              >
                <span id="btn-text">Sign in</span>
                <span id="btn-loading" class="hidden">
                  <svg class="inline-block h-4 w-4 animate-spin mr-2" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                  </svg>
                  Signing in…
                </span>
              </button>
            </div>
          </form>

          <!-- Divider -->
          <div class="my-6 flex items-center gap-3 text-xs text-neutral-400 uppercase before:flex-1 before:border-t before:border-neutral-200 after:flex-1 after:border-t after:border-neutral-200 dark:text-neutral-600 dark:before:border-neutral-700 dark:after:border-neutral-700">
            or continue with
          </div>

          <!-- Google SSO (mock) -->
          <button
            type="button"
            id="google-signin-btn"
            class="flex w-full items-center justify-center gap-3 rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm font-semibold text-neutral-700 shadow-sm transition hover:bg-neutral-50 hover:shadow dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700/70"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>

          <!-- Sign up link -->
          <p class="mt-6 text-center text-sm text-neutral-500 dark:text-neutral-400">
            Don't have an account?
            <a href="/signup" class="ml-1 font-semibold text-blue-600 hover:text-blue-700 hover:underline dark:text-blue-400">Create one free</a>
          </p>
        </div>
      </div>

      <!-- Demo hint -->
      <div class="mt-4 rounded-xl border border-blue-200/60 bg-blue-50/80 px-4 py-3 text-center text-xs text-blue-700 dark:border-blue-800/40 dark:bg-blue-950/30 dark:text-blue-400">
        <span class="font-semibold">Demo credentials:</span> any email + password <span class="font-mono font-semibold">password123</span> (or longer)
      </div>
    </div>
  </section>
</MainLayout>

<script>
  // ── Mock Auth Store ──────────────────────────────────────────────────────────
  const MOCK_USERS: Record<string, { name: string; email: string; password: string; balance: string }> = {
    'demo@alphapay.africa': { name: 'Demo User', email: 'demo@alphapay.africa', password: 'password123', balance: 'GH₵ 4,820.00' },
    'kofi@example.com': { name: 'Kofi Agyeman', email: 'kofi@example.com', password: 'password123', balance: 'GH₵ 12,500.00' },
  };

  // ── DOM Refs ─────────────────────────────────────────────────────────────────
  const form = document.getElementById('signin-form') as HTMLFormElement;
  const emailInput = document.getElementById('signin-email') as HTMLInputElement;
  const passwordInput = document.getElementById('signin-password') as HTMLInputElement;
  const emailError = document.getElementById('email-error')!;
  const passwordError = document.getElementById('password-error')!;
  const errorBanner = document.getElementById('signin-error')!;
  const successBanner = document.getElementById('signin-success')!;
  const btnText = document.getElementById('btn-text')!;
  const btnLoading = document.getElementById('btn-loading')!;
  const signinBtn = document.getElementById('signin-btn') as HTMLButtonElement;
  const togglePasswordBtn = document.getElementById('toggle-password')!;
  const eyeShow = document.getElementById('eye-show')!;
  const eyeHide = document.getElementById('eye-hide')!;
  const googleBtn = document.getElementById('google-signin-btn')!;

  // ── Toggle password visibility ────────────────────────────────────────────────
  togglePasswordBtn.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeShow.classList.toggle('hidden', isPassword);
    eyeHide.classList.toggle('hidden', !isPassword);
  });

  // ── Validation ───────────────────────────────────────────────────────────────
  function validateEmail(val: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
  }

  // ── Submit ───────────────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBanner.classList.add('hidden');

    const email = emailInput.value.trim();
    const password = passwordInput.value;
    let valid = true;

    // Validate email
    if (!validateEmail(email)) {
      emailError.classList.remove('hidden');
      emailInput.classList.add('border-red-400');
      valid = false;
    } else {
      emailError.classList.add('hidden');
      emailInput.classList.remove('border-red-400');
    }

    // Validate password
    if (password.length < 8) {
      passwordError.classList.remove('hidden');
      passwordInput.classList.add('border-red-400');
      valid = false;
    } else {
      passwordError.classList.add('hidden');
      passwordInput.classList.remove('border-red-400');
    }

    if (!valid) return;

    // Show loading state
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');
    signinBtn.disabled = true;

    // Simulate network delay
    await new Promise(r => setTimeout(r, 1200));

    // Mock authentication: known users or any email+password >= 8 chars
    const knownUser = MOCK_USERS[email.toLowerCase()];
    let user = knownUser;

    if (!user) {
      // Create a mock session for unknown users with valid credentials
      const namePart = email.split('@')[0];
      const name = namePart.charAt(0).toUpperCase() + namePart.slice(1);
      user = { name, email, password, balance: 'GH₵ 1,250.00' };
    }

    // Store session in localStorage (mock)
    localStorage.setItem('alphapay_user', JSON.stringify({
      name: user.name,
      email: user.email,
      balance: user.balance,
      loginTime: new Date().toISOString(),
    }));

    // Show success, redirect
    successBanner.classList.remove('hidden');
    btnText.classList.remove('hidden');
    btnLoading.classList.add('hidden');
    signinBtn.disabled = false;

    setTimeout(() => {
      window.location.href = '/dashboard';
    }, 800);
  });

  // ── Google mock SSO ───────────────────────────────────────────────────────────
  googleBtn.addEventListener('click', async () => {
    googleBtn.textContent = 'Connecting to Google…';
    googleBtn.setAttribute('disabled', 'true');
    await new Promise(r => setTimeout(r, 1000));

    localStorage.setItem('alphapay_user', JSON.stringify({
      name: 'Google User',
      email: 'google.user@gmail.com',
      balance: 'GH₵ 3,200.00',
      loginTime: new Date().toISOString(),
    }));

    window.location.href = '/dashboard';
  });
</script>
