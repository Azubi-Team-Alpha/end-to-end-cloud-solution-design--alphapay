{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "main": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "content": {
          "type": "string"
        },
        "imgCard": {
          "type": "string"
        },
        "imgMain": {
          "type": "string"
        },
        "imgAlt": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "content",
        "imgCard",
        "imgMain",
        "imgAlt"
      ]
    },
    "tabs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "dataTab": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "dataTab",
          "title"
        ]
      }
    },
    "longDescription": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "subTitle": {
          "type": "string"
        },
        "btnTitle": {
          "type": "string"
        },
        "btnURL": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "subTitle",
        "btnTitle",
        "btnURL"
      ]
    },
    "descriptionList": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subTitle": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "subTitle"
        ]
      }
    },
    "specificationsLeft": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subTitle": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "subTitle"
        ]
      }
    },
    "specificationsRight": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subTitle": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "subTitle"
        ]
      }
    },
    "tableData": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "feature": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "required": [
          "feature",
          "description"
        ]
      }
    },
    "blueprints": {
      "type": "object",
      "properties": {
        "first": {
          "type": "string"
        },
        "second": {
          "type": "string"
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "main",
    "tabs",
    "longDescription",
    "descriptionList",
    "specificationsLeft",
    "blueprints"
  ]
}