{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "contents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "authorImage": {
      "type": "string"
    },
    "authorImageAlt": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "cardImage": {
      "type": "string"
    },
    "cardImageAlt": {
      "type": "string"
    },
    "readTime": {
      "type": "number"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "contents",
    "author",
    "authorImage",
    "authorImageAlt",
    "pubDate",
    "cardImage",
    "cardImageAlt",
    "readTime"
  ]
}